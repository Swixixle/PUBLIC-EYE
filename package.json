{
  "name": "frame",
  "version": "0.1.0",
  "private": true,
  "description": "Frame — transparency receipts for political claims",
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "prestart": "npm run build",
    "start": "cd apps/api && uvicorn main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "build": "tsc -b tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-keys": "tsx scripts/generate-keys.ts",
    "proof:date": "node -e \"const fs=require('fs'); const d=new Date().toISOString().split('T')[0]; const p=fs.readFileSync('docs/PROOF.md','utf8'); fs.writeFileSync('docs/PROOF.md', p.replace('[date]', d))\"",
    "regen-demo": "npx tsx scripts/regen-demo-payload.ts",
    "e2e": "bash scripts/e2e-test.sh",
    "e2e:local": "bash scripts/e2e-test.sh http://localhost:8000"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "canonicalize": "^2.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.2.4"
  }
}
